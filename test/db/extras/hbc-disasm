NAME=hbc disasm basic instructions (va)
FILE=bins/hbc/bespoke_eval.hbc
ARGS=-e asm.sub.varmin=16
CMDS=<<EOF
pd 3
EOF
EXPECT=<<EOF
            ;-- entry0:
            ;-- global_0x000000b0:
            0x100000b0      73000100       load_const_string r0, 0xa2  ; str.print_123__
                                                                       ; 0x100000a2 ; "print(123);"
            0x100000b4      5e000000       direct_eval r0, r0, 0
            0x100000b8      5c00           ret r0
EOF
RUN

